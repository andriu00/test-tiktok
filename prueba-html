<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cargando...</title>
    <style>
        body { font-family: -apple-system, system-ui, sans-serif; text-align: center; padding: 40px 20px; background: #fff; color: #333; }
        .loader { border: 4px solid #f3f3f3; border-top: 4px solid #000; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 20px auto; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        
        .btn { display: none; background: #010101; color: white; padding: 18px 25px; border-radius: 12px; text-decoration: none; font-weight: bold; font-size: 18px; margin-top: 20px; }
        
        /* Estilo para la guía de iPhone */
        #ios-guide { display: none; margin-top: 30px; padding: 15px; border: 1px dashed #ccc; border-radius: 10px; background: #fafafa; }
        .steps { text-align: left; font-size: 14px; color: #666; display: inline-block; }
    </style>
</head>
<body>

    <div id="loader" class="loader"></div>
    <h2 id="main-title">Preparando tu lectura...</h2>
    
    <a href="#" id="btn-action" class="btn">VER EN EL NAVEGADOR</a>

    <div id="ios-guide">
        <p><strong>Si no redirige automáticamente:</strong></p>
        <div class="steps">
            1. Toca los <strong>tres puntos (···)</strong> arriba.<br>
            2. Selecciona <strong>"Abrir en el navegador"</strong>.
        </div>
    </div>

    <script>
        const finalUrl = "astratienda.com/"; // CAMBIA ESTO
        const ua = navigator.userAgent || navigator.vendor || window.opera;
        
        const isTikTok = ua.includes("TikTok");
        const isAndroid = /Android/i.test(ua);
        const isIOS = /iPhone|iPad|iPod/i.test(ua);

        const btn = document.getElementById('btn-action');
        const loader = document.getElementById('loader');
        const guide = document.getElementById('ios-guide');

        function ejecutarSalto() {
            if (isAndroid) {
                // El método que ya te funcionó
                window.location.href = "intent://" + finalUrl + "#Intent;scheme=https;package=com.android.chrome;end";
            } 
            else if (isIOS) {
                // TRUCO PARA IPHONE: Intentar forzar Safari mediante un "blob"
                // Esto engaña a TikTok para que pida abrir fuera
                const link = document.createElement('a');
                link.href = "https://" + finalUrl;
                link.download = "info.html"; // Esto dispara la alerta de sistema en iOS
                link.click();
                
                // Fallback inmediato por si el truco falla
                setTimeout(() => {
                    window.location.href = "https://" + finalUrl;
                }, 500);
            } 
            else {
                window.location.href = "https://" + finalUrl;
            }
        }

        if (isTikTok) {
            // En TikTok siempre mostramos el botón para asegurar el "clic" del usuario
            loader.style.display = "none";
            btn.style.display = "inline-block";
            
            if (isIOS) {
                guide.style.display = "block";
                document.getElementById('main-title').innerText = "Casi listo...";
            }

            btn.onclick = function(e) {
                e.preventDefault();
                ejecutarSalto();
            };
        } else {
            // Si está fuera de TikTok, salta solo
            ejecutarSalto();
        }
    </script>
</body>
</html>
